<div class="product_full {{ class }}">

    <h1>{{ title }}</h1>

    {% if hasMetaFields %}

        {% set meta = meta %}

        <div class="meta">
            <div class="info">
                <time datetime="{{ datetime }}">{{ meta.date }}</time>

                {% if meta.brand is defined %}
                    <span class="brand">{{ meta.brand_text }}: <span>{{ meta.brand }}</span></span>
                {% endif %}

                {% if meta.model is defined %}
                    <span class="model">{{ meta.model_text }}: <span>{{ meta.model }}</span></span>
                {% endif %}

                {% if meta.sku is defined %}
                    <span class="sku">{{ meta.sku_text }}: <span>{{ meta.sku }}</span></span>
                {% endif %}

                {% if meta.global_ID is defined %}
                    <span class="global_ID {{ meta.global_ID.unit }}">
                        {{ meta.global_ID.name }}:
                        <span>{{ meta.global_ID.value }}</span>
                    </span>
                {% endif %}
            </div>

            <div class="offer">
                {% if meta.price is iterable %}
                    {{ meta.price_text }}:
                    <span>{{ meta.price.value|number_format }}</span>
                    <span>{{ meta.price.symbol }}</span>
                {% endif %}

                {% if meta.availability is defined %}
                    <span class="availability {{ meta.availability.class }}">
                        ({{ meta.availability.value }})
                    </span>
                {% endif %}

                {% if meta.buy is defined %}
                    <span class="buy">
                        <a href="{{ url }}"
                           class="hyperlink_txt"
                           title="{{ linkTitle }}"
                           {% if target %}target="_blank" rel="nofollow"{% endif %}>
                            {{ titleText ?: url }}
                        </a>
                    </span>
                {% endif %}
            </div>
        </div>

    {% endif %}

    {% if hasSummary %}
        <div class="summary">

            {{ summary|raw }}

            {% if addImage %}
                {% if link %}<a href="{{ link }}">{% endif %}

                {{ include('@Contao/image.html.twig', arrData|default({})) }}

                {% if link %}</a>{% endif %}
            {% endif %}

        </div>
    {% endif %}

    {% if hasText %}
        {{ text|raw }}
    {% endif %}

    {% if hasEnclosure %}
        <div class="enclosure">
            {% for enclosure in enclosure %}
                <p>
                    <img src="{{ enclosure.icon }}"
                         width="18"
                         height="18"
                         alt="{{ enclosure.mime }}"
                         class="mime_icon">

                    <a href="{{ enclosure.href }}" title="{{ enclosure.title }}">
                        {{ enclosure.link }}
                        <span class="size">({{ enclosure.filesize }})</span>
                    </a>
                </p>
            {% endfor %}
        </div>
    {% endif %}

</div>